# Supabase project URL, for example:
# https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_URL=

# Supabase publishable/anon key. This is safe to expose to the browser.
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Supabase secret/service role key. Server-only. Never expose this in client code.
SUPABASE_SERVICE_ROLE_KEY=

# Public app URL. Use your Vercel production URL after deployment.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
